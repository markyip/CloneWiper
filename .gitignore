# =============================================================================
# CloneWiper — ignore rules
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg
.installed.cfg
MANIFEST
pip-wheel-metadata/
share/python-wheels/

# --- Virtual environments ---
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# --- PyInstaller / frozen builds ---
build/
dist/
*.spec
*.manifest
*.app/
*.dmg
*.pkg
warn-*.txt
*.toc

# Built artifacts (do not commit binaries)
*.exe

# --- IDE & editors ---
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.pydevproject
.settings/

# --- OS junk ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# --- CloneWiper runtime data (local caches / DBs) ---
# *.db covers thumbnails.db, phash/md5 caches, and local test DBs
*.db
*.sqlite
*.sqlite3
cache/
Cache/
*.log
*.cache

# --- Testing & coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/
*.cover
coverage.xml
.ruff_cache/

# --- Type checkers / linters ---
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# --- Documentation builds ---
docs/_build/
site/

# --- Jupyter ---
.ipynb_checkpoints

# --- Packaging / legacy layout ---
develop-eggs/
downloads/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/

# --- Environment & secrets ---
.env
.env.*
!.env.example

# --- pyenv / PEP 582 ---
.python-version
__pypackages__/

# --- Celery (unused; harmless) ---
celerybeat-schedule
celerybeat.pid

# --- SageMath ---
*.sage.py

# --- Cython generated (narrow; do not use blanket *.html) ---
*.c

# --- Temporary files ---
*.tmp
*.temp
*.bak
*.backup
*.old

# --- Icons: generated iconset only ---
icons/*.iconset/
!icons/README.md
